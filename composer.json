{
    "name": "ttek/tk-form",
    "type": "library",
    "description": "Tk Lib: Form render with DOM and PHP templates",
    "keywords":  [
        "tropotek",
        "Form"
    ],
    "time": "2025-05-08",
    "license": "MIT",
    "minimum-stability": "dev",
    "authors":  [
         {
            "name": "Michael Mifsud",
            "homepage": "https://www.tropotek.com/"
        }
    ],
    "autoload":  {
        "psr-4":  {
            "Tk\\": "Tk/"
        }
    },
    "require":  {
        "php": "^8.3",
        "ext-dom": "*",
        "ttek/tk-framework": "^8.0",
        "ttek/tk-domtemplate": "^8.0"
    },
    "extra":  {
        "branch-alias":  {
            "dev-master": "8.0.x-dev"
        }
    },
    "config": {
        "preferred-install": {
            "ttek/*": "source"
        }
    }
}